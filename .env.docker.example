COMPOSE_PROJECT_NAME=repair-crm

CRM_APP_IMAGE=repair-crm-app:latest
CRM_WEB_IMAGE=repair-crm-web:latest
CRM_DB_IMAGE=postgres:17-alpine
CRM_REDIS_IMAGE=redis:7-alpine

DOCKER_APP_HTTP_PORT=10005

NGINX_CLIENT_MAX_BODY_SIZE=32m
PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=120
PHP_UPLOAD_MAX_FILESIZE=32M
PHP_POST_MAX_SIZE=32M

APP_RUN_MIGRATIONS=true
APP_RUN_OPTIMIZE=true

APP_NAME="Repair CRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://crm.reslab.pro
APP_TIMEZONE=Europe/Kyiv

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=repair_crm
DB_USERNAME=repair_crm
DB_PASSWORD=change_me

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@crm.reslab.pro"
MAIL_FROM_NAME="${APP_NAME}"
